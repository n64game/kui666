{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kui666",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-15",
  "workers_dev": true,
  "vars": {
    "ADMIN_USERNAME": "adminjd",
    "ADMIN_PASSWORD": "admin618618",
    "PROXY_USER": "kuijd",
    "PROXY_PASS": "kui618618"
  },
  "assets": {
    "directory": "static",
    "binding": "ASSETS",
    "run_worker_first": ["/api", "/api/*", "/health", "/agent/ws", "/dashboard/*", "/public/*", "/notify", "/public-policy", "/frequency-policy"]
  },
  "d1_databases": [
    {
      "binding": "DB","database_id": "740a7f46-d564-4cbb-b0fe-b38427083c2b","database_name": "kui666"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "durable_objects": {
    "bindings": [
      { "name": "VPS_PRESENCE", "class_name": "VpsPresence" },
      { "name": "DASHBOARD_HUB", "class_name": "DashboardHub" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["VpsPresence", "DashboardHub"]
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
